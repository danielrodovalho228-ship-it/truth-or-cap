{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/admin/cost-check",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/qotd-challenge",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/expire-lapsed-premium",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/purge-expired-games",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/close-stale-rooms",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/cleanup-orphan-players",
      "schedule": "0 3 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(self), microphone=(self), geolocation=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    },
    {
      "source": "/admin/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/auth/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ],
  "functions": {
    "app/api/analyze/route.ts": {
      "maxDuration": 60
    }
  }
}
