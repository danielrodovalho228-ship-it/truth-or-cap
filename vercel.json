{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/admin/cost-check",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/qotd-challenge",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/expire-lapsed-premium",
      "schedule": "0 5 * * *"
    }
  ],
  "headers": [
    {
      "source": "/admin/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/auth/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ]
}
