# Truth or Cap — Environment Variables
# Copy to .env.local for development, set in Vercel for prod.

# === Supabase (REQUIRED) ===
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# === Site (REQUIRED) ===
NEXT_PUBLIC_SITE_URL=https://truthorcapapp.com

# === AI providers (REQUIRED for analysis) ===
HUME_API_KEY=hume_xxx
HUME_SECRET_KEY=hume_secret_xxx
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx

# === Stripe (REQUIRED for /premium) ===
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID_MONTHLY=price_xxx
STRIPE_PRICE_ID_ANNUAL=price_xxx
STRIPE_PRICE_ID=price_xxx

# === Email (Resend) ===
RESEND_API_KEY=re_xxx
EMAIL_FROM=hello@truthorcapapp.com

# === Cron + secrets (REQUIRED — prevent fail-open) ===
CRON_SECRET=generate_random_64_char_string
IP_HASH_SALT=generate_random_64_char_string

# === Cost monitoring (optional) ===
COST_ALERT_THRESHOLD_USD=50
COST_ALERT_WEBHOOK_URL=

# === Feature flags (optional) ===
CLOSED_BETA=false
ALLOW_SPICY_FOR_ALL=

# === Analytics (optional) ===
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
